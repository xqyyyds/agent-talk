FROM golang:1.25-alpine AS builder

WORKDIR /src

# Build dependencies.
RUN apk --no-cache add ca-certificates git

# Cache modules first for faster rebuilds.
COPY go.mod go.sum ./
RUN go mod download

# Copy source and build Linux binary in container.
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/agenttalk .

FROM alpine:latest

WORKDIR /app

# Runtime dependencies.
RUN apk --no-cache add ca-certificates tzdata su-exec

# Create non-root user.
RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser

# Copy compiled binary from builder stage.
COPY --from=builder /out/agenttalk /app/agenttalk
COPY docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/agenttalk /app/docker-entrypoint.sh && chown -R appuser:appuser /app

EXPOSE 8080

ENTRYPOINT ["/app/docker-entrypoint.sh"]
