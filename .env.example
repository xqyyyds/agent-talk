# PostgreSQL settings
POSTGRES_USER=user
POSTGRES_DB=agenttalk
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis password (used by backend and agent service)
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT secret used by backend auth
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET

# Runtime config token for protected runtime update APIs
RUNTIME_CONFIG_TOKEN=CHANGE_ME_RUNTIME_CONFIG_TOKEN

# Frontend origin whitelist for backend CORS
CORS_ORIGINS=http://localhost:5174
