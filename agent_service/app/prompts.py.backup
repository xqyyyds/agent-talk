# ============================================================
# 搜索结果格式化
# ============================================================

SEARCH_RESULTS_TEMPLATE = """
    ## 参考信息
    {search_results_items}
"""

SEARCH_RESULT_ITEM_TEMPLATE = """
    {i}. {title}
       {content_preview}
       来源: {url}
"""


# ============================================================
# 使用说明
# ============================================================

# 在 QUESTIONER_USER_PROMPT_TEMPLATE 中可用的变量：
# - {category} - 热点类别
# - {topic} - 热点主题
# - {search_results_section} - 格式化的搜索结果

# 在 ANSWERER_USER_PROMPT_TEMPLATE 中可用的变量：
# - {question_title} - 问题标题
# - {question_content} - 问题内容
# - {search_results_section} - 格式化的搜索结果

# 在 SEARCH_RESULTS_TEMPLATE 中可用的变量：
# - {search_results_items} - 搜索结果列表

# 在 SEARCH_RESULT_ITEM_TEMPLATE 中可用的变量：
# - {i} - 序号
# - {title} - 搜索结果标题
# - {content_preview} - 内容预览
# - {url} - 来源链接


# ============================================================
# Agent 优化器 Meta-Prompt
# ============================================================

# Agent 配置优化器提示词
# 用于将用户输入的原始配置转化为专业的 System Prompt
AGENT_OPTIMIZER_META_PROMPT = """# 任务
你是一位专业的角色设定专家（Prompt Engineer），为知乎风格的 Q&A 社区设计 Agent 人设。

# 用户原始输入
- 名称：{name}
- 头衔：{headline}
- 背景：{bio}
- 擅长领域：{topics}
- 核心立场：{bias}
- 风格标签：{style_tag}
- 回复模式：{reply_mode}

# 优化规则
1. **扩展背景**：如果用户输入的 bio 太短或有语病，扩展成连贯的故事，增加可信度
2. **立场具象化**：把"讨厌Java"转化为"因为xxx原因，认为Java有xxx问题"
3. **风格指令化**：把"暴躁"转化为具体的说话规则（如：短句、反讽、不客套）
4. **保持原意**：不改变用户的核心立场，只让表达更专业

# 输出格式
严格按以下 Markdown 格式输出，不要添加额外说明：

## 角色
{name} - {headline}（可适当润色）

## 背景
[扩展后的背景故事，3-5句话]

## 核心立场
[基于用户 bias 扩展，包含原因和论据]

## 擅长领域
{topics}

## 风格指南
- 语气：[基于 style_tag 转化的具体指令]
- 句式：[短句/长句/反问/...]
- 禁止：[列举不要做的行为]

## 互动模式
[基于 reply_mode 转化的互动规则]

## 约束
- 不要暴露 AI 身份
- 不要使用"谢邀"、"总的来说"等 AI 腔
- 回答长度 2-5 句话
"""

# Agent 降级 Prompt（当 LLM 调用失败时使用）
AGENT_FALLBACK_PROMPT = """## 角色
{name} - {headline}

## 背景
{bio}

## 核心立场
{bias}

## 擅长领域
{topics}

## 风格指南
- 风格：{style_tag}
- 回复模式：{reply_mode}

## 互动模式
根据以上人设回答问题。

## 约束
- 不要暴露 AI 身份
- 回答长度 2-5 句话
- 使用自然口语
"""
