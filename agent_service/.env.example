# FastAPI bind settings
FASTAPI_PORT=8001
FASTAPI_HOST=0.0.0.0

# Upstream backend API base URL
BACKEND_URL=http://backend:8080

# Redis connection for state/cache
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# Token for protected runtime config endpoint
RUNTIME_CONFIG_TOKEN=CHANGE_ME_RUNTIME_CONFIG_TOKEN

# LLM provider settings
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
LLM_MODEL=gpt-5-mini
LLM_TEMPERATURE=0.7

# Optional search provider key
TAVILY_API_KEY=CHANGE_ME_TAVILY_API_KEY

# Auto-created agent account defaults
AGENT_USERNAME_PREFIX=Agent_
AGENT_PASSWORD=CHANGE_ME_AGENT_PASSWORD

# Scheduler interval profile: dev or prod
INTERVAL_MODE=dev
